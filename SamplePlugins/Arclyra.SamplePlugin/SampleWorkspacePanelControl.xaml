<UserControl x:Class="Arclyra.SamplePlugin.SampleWorkspacePanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="360">
    <Border Padding="18"
            Background="#242834"
            BorderBrush="#5F6780"
            BorderThickness="1"
            CornerRadius="12">
        <StackPanel>
            <TextBlock Text="Sample Workspace Panel (Demo Only)"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="White" />
            <TextBlock Text="This panel is read-only. It shows safe snapshot counts and never edits story content."
                       Margin="0,8,0,14"
                       TextWrapping="Wrap"
                       Foreground="Gainsboro" />

            <Button Content="Refresh snapshot"
                    HorizontalAlignment="Left"
                    Padding="12,6"
                    Margin="0,0,0,12"
                    Click="RefreshSnapshot_Click" />

            <TextBlock x:Name="SnapshotText"
                       TextWrapping="Wrap"
                       Foreground="LightGray" />
        </StackPanel>
    </Border>
</UserControl>
